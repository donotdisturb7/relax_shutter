# Change these key values
APP_ENV=production
APP_DEBUG=false
APP_URL=https://your-production-domain.com

# Database Configuration
# Replace with Render's PostgreSQL details
DB_CONNECTION=pgsql
DB_HOST=[Render PostgreSQL Host]
DB_PORT=5432
DB_DATABASE=[Render Database Name]
DB_USERNAME=[Render Database Username]
DB_PASSWORD=[Render Database Password]

# Session and Broadcast Configuration
SESSION_DRIVER=database
BROADCAST_CONNECTION=log

# # Mail Configuration (use a transactional email service)
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.mailgun.org  # or another service
# MAIL_PORT=587
# MAIL_USERNAME=[Your Mailgun Username]
# MAIL_PASSWORD=[Your Mailgun Password]
# MAIL_ENCRYPTION=tls